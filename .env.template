# ============================================================================
# HIVMARKET BACKEND CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to Backend/backend/.env and fill in your values
# ============================================================================

# DATABASE CONFIGURATION
# ============================================================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hivemarket
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD

# CLOUDINARY CONFIGURATION (Image Upload)
# ============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# PAYSTACK PAYMENT CONFIGURATION
# ============================================================================

# MODE: Set to 'test' for development or 'live' for production
# IMPORTANT: Only change to 'live' when ready for production!
PAYSTACK_MODE=test

# TEST KEYS (for development - use test cards)
# Get from: https://dashboard.paystack.com → Settings → Developer
# Test Card: 4111 1111 1111 1111
PAYSTACK_SECRET_KEY_TEST=sk_test_YOUR_TEST_SECRET_KEY_HERE
PAYSTACK_PUBLIC_KEY_TEST=pk_test_YOUR_TEST_PUBLIC_KEY_HERE

# LIVE KEYS (for production - use real cards)
# ⚠️  NEVER commit live keys to version control!
# ⚠️  Use environment variables or secure vault in production
PAYSTACK_SECRET_KEY_LIVE=sk_live_YOUR_LIVE_SECRET_KEY_HERE
PAYSTACK_PUBLIC_KEY_LIVE=pk_live_YOUR_LIVE_PUBLIC_KEY_HERE

# PAYSTACK API BASE URL
# In test mode: api.paystack.co (same for both test and live)
PAYSTACK_BASE_URL=https://api.paystack.co

# PAYSTACK CALLBACK/WEBHOOK URL
# Frontend will redirect here after payment
# Local development example (use ngrok for local testing):
#   PAYSTACK_CALLBACK_URL=http://localhost:8080/api/payments/callback
# Production example:
#   PAYSTACK_CALLBACK_URL=https://yourdomain.com/api/payments/callback
PAYSTACK_CALLBACK_URL=http://localhost:8080/api/payments/callback

# ============================================================================
# INSTRUCTIONS
# ============================================================================
#
# 1. GET TEST KEYS:
#    - Go to https://dashboard.paystack.com
#    - Login with your Paystack account
#    - Click Settings → Developer
#    - Copy Test Secret Key (sk_test_...)
#    - Copy Test Public Key (pk_test_...)
#
# 2. UPDATE THIS FILE:
#    - Replace PAYSTACK_SECRET_KEY_TEST with your test secret key
#    - Replace PAYSTACK_PUBLIC_KEY_TEST with your test public key
#    - Save as Backend/backend/.env
#
# 3. RESTART BACKEND:
#    cd Backend/backend
#    mvn spring-boot:run
#
# 4. TEST WITH TEST CARD:
#    Card: 4111 1111 1111 1111
#    Expiry: 12/25
#    CVV: 123
#    OTP: 123456
#
# 5. FOR PRODUCTION:
#    - Get live keys from Paystack dashboard
#    - Change PAYSTACK_MODE=live
#    - Update live keys
#    - DO NOT commit keys to git
#    - Use environment variables instead
#
# ============================================================================
